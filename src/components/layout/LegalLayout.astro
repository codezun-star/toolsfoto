---
import Header from './Header.astro';
import Footer from './Footer.astro';
import '@/styles/global.css';
import { PAGE_SEO, SITE } from '@/lib/constants/seo';

interface Props {
  slug: string;
  title: string;
}

const { slug, title } = Astro.props;
const seo = PAGE_SEO[slug];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={seo.canonical} />
    <meta name="robots" content="noindex, follow" />

    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image" content={SITE.ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={seo.canonical} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Header />

    <main class="max-w-3xl mx-auto px-4 sm:px-6 py-10">
      <nav class="flex items-center gap-2 text-sm text-[var(--color-text-muted)] mb-8">
        <a href="/" class="hover:text-[var(--color-text)] transition-colors">Inicio</a>
        <span>/</span>
        <span class="text-[var(--color-text)]">{title}</span>
      </nav>

      <article class="prose-legal">
        <slot />
      </article>
    </main>

    <Footer />
  </body>
</html>

<style>
  .prose-legal {
    color: var(--color-text);
    line-height: 1.75;
  }
  .prose-legal :global(h1) {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }
  .prose-legal :global(.updated) {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin-bottom: 2.5rem;
    display: block;
  }
  .prose-legal :global(h2) {
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }
  .prose-legal :global(p) {
    margin-bottom: 1rem;
    color: var(--color-text-secondary);
  }
  .prose-legal :global(ul) {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
    color: var(--color-text-secondary);
  }
  .prose-legal :global(ul li) {
    margin-bottom: 0.375rem;
  }
  .prose-legal :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose-legal :global(a:hover) {
    opacity: 0.8;
  }
  .prose-legal :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }
  .prose-legal :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }
  .prose-legal :global(.highlight-box) {
    background: var(--color-accent-bg);
    border: 1px solid #fad5cc;
    border-radius: 0.5rem;
    padding: 1rem 1.25rem;
    margin-bottom: 2rem;
  }
  .prose-legal :global(.highlight-box p) {
    margin-bottom: 0;
    color: var(--color-text);
    font-weight: 500;
  }
</style>
