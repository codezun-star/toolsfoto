---
const currentPath = Astro.url.pathname;
---
<header class="sticky top-0 z-50 bg-white border-b border-[var(--color-border)]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 h-20 flex items-center justify-between gap-4">
    <a href="/" class="shrink-0 hover:opacity-80 transition-opacity" aria-label="ToolsFoto — inicio">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 680 220" width="148" height="48" aria-hidden="true">
        <rect x="0" y="0" width="680" height="220" fill="#FFFFFF" rx="10"/>
        <rect x="0" y="155" width="680" height="65" fill="#1A1A1A"/>
        <rect x="0" y="210" width="680" height="10" fill="#1A1A1A"/>
        <text x="340" y="118" text-anchor="middle" font-family="'Segoe UI', Arial, Helvetica, sans-serif" font-size="72" font-weight="700" letter-spacing="-2" fill="#1A1A1A">Tools<tspan fill="#0BBFB0">Foto</tspan></text>
        <text x="340" y="186" text-anchor="middle" font-family="'Segoe UI', Arial, Helvetica, sans-serif" font-size="11.5" font-weight="400" letter-spacing="4" fill="#888888">IMÁGENES · VÍDEO · AUDIO · PDF · DEV</text>
      </svg>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-1 text-sm font-medium text-[var(--color-text-secondary)]">
      <a href="/" class={`px-3 py-1.5 rounded-lg transition-colors ${currentPath === '/' ? 'text-[var(--color-accent)] bg-[var(--color-accent-bg)]' : 'hover:text-[var(--color-text)] hover:bg-[var(--color-bg)]'}`}>Inicio</a>
      <a href="/#imagen" class="px-3 py-1.5 rounded-lg hover:text-[var(--color-text)] hover:bg-[var(--color-bg)] transition-colors">Imágenes</a>
      <a href="/#pdf" class="px-3 py-1.5 rounded-lg hover:text-[var(--color-text)] hover:bg-[var(--color-bg)] transition-colors">PDF</a>
      <a href="/#video" class="px-3 py-1.5 rounded-lg hover:text-[var(--color-text)] hover:bg-[var(--color-bg)] transition-colors">Vídeo</a>
      <a href="/#audio" class="px-3 py-1.5 rounded-lg hover:text-[var(--color-text)] hover:bg-[var(--color-bg)] transition-colors">Audio</a>
      <a href="/#developer" class="px-3 py-1.5 rounded-lg hover:text-[var(--color-text)] hover:bg-[var(--color-bg)] transition-colors">Developer</a>
    </nav>

    <div class="flex items-center gap-2">
      <a
        href="/comprimir"
        class="px-4 py-2 rounded-lg bg-[var(--color-accent)] text-white text-sm font-semibold hover:bg-[#C93D1E] transition-colors"
      >
        Usar gratis
      </a>
      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg text-[var(--color-text-secondary)] hover:text-[var(--color-text)] hover:bg-[var(--color-bg)] transition-colors"
        aria-label="Abrir menú"
      >
        <svg id="icon-menu" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/>
        </svg>
        <svg id="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-[var(--color-border)] bg-white">
    <nav class="max-w-6xl mx-auto px-4 py-3 flex flex-col gap-1 text-sm font-medium">
      <a href="/" class="px-3 py-2.5 rounded-lg text-[var(--color-text-secondary)] hover:text-[var(--color-text)] hover:bg-[var(--color-bg)] transition-colors">Inicio</a>
      <a href="/#imagen" class="px-3 py-2.5 rounded-lg text-[var(--color-text-secondary)] hover:text-[var(--color-text)] hover:bg-[var(--color-bg)] transition-colors">Imágenes</a>
      <a href="/#pdf" class="px-3 py-2.5 rounded-lg text-[var(--color-text-secondary)] hover:text-[var(--color-text)] hover:bg-[var(--color-bg)] transition-colors">PDF</a>
      <a href="/#video" class="px-3 py-2.5 rounded-lg text-[var(--color-text-secondary)] hover:text-[var(--color-text)] hover:bg-[var(--color-bg)] transition-colors">Vídeo</a>
      <a href="/#audio" class="px-3 py-2.5 rounded-lg text-[var(--color-text-secondary)] hover:text-[var(--color-text)] hover:bg-[var(--color-bg)] transition-colors">Audio</a>
      <a href="/#developer" class="px-3 py-2.5 rounded-lg text-[var(--color-text-secondary)] hover:text-[var(--color-text)] hover:bg-[var(--color-bg)] transition-colors">Developer</a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconMenu?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });

  // Close menu when a nav link is clicked
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconMenu?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });
</script>
