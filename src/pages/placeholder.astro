---
import ToolLayout from '@/components/layout/ToolLayout.astro';
import PlaceholderTool from '@/components/tools/PlaceholderTool';

const faqs = [
  { q: '¿Qué es una imagen placeholder?', a: 'Una imagen placeholder es una imagen genérica usada durante el desarrollo web para representar el espacio que ocupará una imagen real. Sirve para prototipar diseños sin necesitar imágenes definitivas.' },
  { q: '¿Qué presets de dimensiones están disponibles?', a: 'Incluye presets para los formatos más comunes: 16:9 (1280×720), cuadrado 1:1 (800×800), 4:3 (1024×768), Open Graph (1200×630) y Banner (1500×500). También puedes introducir dimensiones personalizadas.' },
  { q: '¿Puedo personalizar el texto que aparece en la imagen?', a: 'Sí. Por defecto muestra las dimensiones (ej: 800×600), pero puedes escribir cualquier texto personalizado en el campo correspondiente.' },
  { q: '¿En qué formato se descarga la imagen?', a: 'Las imágenes placeholder se descargan en formato PNG para máxima compatibilidad y soporte de transparencia.' },
  { q: '¿Puedo usar estas imágenes en proyectos comerciales?', a: 'Sí. Las imágenes se generan completamente en tu navegador y son de tu propiedad. No hay restricciones de uso.' },
];
---
<ToolLayout slug="placeholder" faqs={faqs}>
  <PlaceholderTool client:load />
</ToolLayout>
