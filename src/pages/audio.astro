---
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import CategoryGrid from '@/components/ui/CategoryGrid';
import { TOOLS } from '@/lib/constants/tools';
import { PAGE_SEO, SITE } from '@/lib/constants/seo';
import '@/styles/global.css';

const tools = TOOLS.filter(t => t.domain === 'audio');
const seo = PAGE_SEO['audio'];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={seo.canonical} />

    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image" content={SITE.ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={seo.canonical} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={SITE.ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon-192.png" />
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-JDPXVTKVCL"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-JDPXVTKVCL');
    </script>
  </head>
  <body>
    <Header />

    <div class="bg-[var(--color-text)] pt-14">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
        <nav class="flex items-center gap-2 text-xs text-[#888] mb-6 font-mono">
          <a href="/" class="hover:text-white transition-colors">Inicio</a>
          <span>/</span>
          <span style="color: #0BBFB0;">Audio</span>
        </nav>
        <div class="flex items-start justify-between gap-6 flex-wrap">
          <div>
            <h1 class="text-4xl sm:text-5xl font-extrabold text-white leading-tight mb-3" style="letter-spacing: -0.5px;">
              Herramientas de audio
            </h1>
            <p class="text-[#999] text-base max-w-xl leading-relaxed">
              Comprime, convierte, corta, mezcla y edita audio online gratis. Sin registro, todo se procesa en tu navegador.
            </p>
          </div>
          <div class="shrink-0 self-start">
            <span class="inline-flex items-center px-3 py-1.5 rounded-full bg-white/10 border border-white/20 text-sm font-medium text-white font-mono">
              {tools.length} herramientas
            </span>
          </div>
        </div>
      </div>
    </div>

    <main class="bg-[var(--color-tools-bg)] border-b border-[var(--color-tools-border)] py-10 min-h-[60vh]">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <CategoryGrid domain="audio" client:load />
      </div>
    </main>

    <Footer />
    <script is:inline>(function(s){s.dataset.zone='11097756',s.src='https://nap5k.com/tag.min.js'})([document.documentElement, document.body].filter(Boolean).pop().appendChild(document.createElement('script')))</script>
    <script is:inline>(function(s){s.dataset.zone='11097758',s.src='https://n6wxm.com/vignette.min.js'})([document.documentElement, document.body].filter(Boolean).pop().appendChild(document.createElement('script')))</script>
  </body>
</html>
