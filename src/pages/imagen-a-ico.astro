---
import ToolLayout from '@/components/layout/ToolLayout.astro';
import ImagenAICOTool from '@/components/tools/ImagenAICOTool';

const faqs = [
  { q: '¿Qué es un archivo ICO?', a: 'Un archivo ICO es el formato de icono estándar en Windows. Puede contener múltiples versiones de la misma imagen en distintos tamaños (16, 32, 48, 64, 128, 256px) dentro de un único archivo, y el sistema operativo usa el tamaño más apropiado según el contexto.' },
  { q: '¿Qué tamaños debería incluir para un favicon?', a: 'Para un favicon web se recomiendan al menos 16×16, 32×32 y 48×48 px. Para iconos de aplicación de escritorio conviene añadir también 64×64 y 128×128 px.' },
  { q: '¿Se conserva la transparencia del PNG original?', a: 'Sí. Los ICO modernos (generados por esta herramienta) contienen PNGs con canal alfa completo, por lo que la transparencia se preserva perfectamente en todos los tamaños.' },
  { q: '¿Con qué navegadores y sistemas es compatible este ICO?', a: 'El formato ICO con PNGs embebidos es compatible con Windows Vista en adelante, todos los navegadores modernos (Chrome, Firefox, Safari, Edge), y la mayoría de lectores de correo.' },
  { q: '¿Qué tipo de imagen es mejor para convertir a ICO?', a: 'Las imágenes cuadradas (1:1) con fondo transparente dan los mejores resultados. Si tu imagen no es cuadrada, el conversor la redimensionará manteniendo las proporciones dentro del marco cuadrado.' },
];
---
<ToolLayout slug="imagen-a-ico" faqs={faqs}>
  <ImagenAICOTool client:load />
</ToolLayout>
