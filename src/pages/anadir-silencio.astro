---
import ToolLayout from '@/components/layout/ToolLayout.astro';
import AnadirSilencioTool from '@/components/tools/AnadirSilencioTool';

const faqs = [
  { q: '¿Para qué sirve añadir silencio a un audio?', a: 'Añadir silencio es útil para dar un margen antes de que empiece la música o la voz (fade in natural), para que el audio no se corte bruscamente al inicio o al final en reproductores, para sincronizar pistas en edición de vídeo, o para cumplir requisitos de duración mínima en plataformas de distribución.' },
  { q: '¿Cuánto silencio puedo añadir?', a: 'Puedes añadir entre 0 y 10 segundos de silencio al inicio y otros 0-10 segundos al final, con pasos de 0.5 segundos. Ambos ajustes son independientes. Si los dos están en 0, el botón de proceso estará desactivado.' },
  { q: '¿Se preserva el formato original del audio?', a: 'Sí. Si subes un MP3 el resultado es MP3, un WAV produce un WAV, etc. Los formatos compatibles son MP3, WAV, OGG, AAC y FLAC.' },
  { q: '¿El procesamiento sube mis archivos a algún servidor?', a: 'No. El procesamiento se realiza 100% en tu navegador con FFmpeg.wasm. Tus archivos de audio nunca salen de tu dispositivo.' },
  { q: '¿Por qué tarda la primera vez?', a: 'La primera vez que uses cualquier herramienta de audio, el navegador descarga el motor FFmpeg.wasm (~30 MB). Este archivo queda en caché del navegador, por lo que las siguientes operaciones son prácticamente instantáneas.' },
];
---
<ToolLayout slug="anadir-silencio" faqs={faqs}>
  <AnadirSilencioTool client:load />
</ToolLayout>
