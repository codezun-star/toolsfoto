---
import ToolLayout from '@/components/layout/ToolLayout.astro';
import GifAVideoTool from '@/components/tools/GifAVideoTool';

const faqs = [
  { q: '¿Por qué convertir un GIF a MP4?', a: 'Los archivos MP4 son mucho más eficientes que los GIF: pueden ser hasta 10 veces más pequeños con la misma calidad visual. Además, MP4 tiene soporte nativo en todas las redes sociales, WhatsApp y reproductores modernos, mientras que los GIF grandes pueden no cargarse correctamente.' },
  { q: '¿El MP4 resultante tendrá audio?', a: 'No. Los GIFs no tienen pista de audio, por lo que el MP4 resultante será un vídeo silencioso. Si quieres añadir música o audio, puedes usar la herramienta "Añadir audio a vídeo" después.' },
  { q: '¿Se mantiene la animación y la velocidad del GIF?', a: 'Sí. FFmpeg lee los frames y la velocidad de fotogramas del GIF original. La animación en el MP4 tendrá la misma velocidad y número de frames que el GIF de origen.' },
  { q: '¿Qué tamaño máximo de GIF admite?', a: 'El límite es 100 MB. La mayoría de GIFs web son mucho menores. Si tu GIF supera ese límite, considera reducir su tamaño con otra herramienta antes de convertirlo.' },
  { q: '¿Por qué tarda en cargar la primera vez?', a: 'La primera vez se descarga el procesador FFmpeg.wasm (~30 MB). El navegador lo guarda en caché para las siguientes sesiones. El GIF nunca sale de tu dispositivo.' },
];
---
<ToolLayout slug="gif-a-video" faqs={faqs}>
  <GifAVideoTool client:load />
</ToolLayout>
