---
import ToolLayout from '@/components/layout/ToolLayout.astro';
import ExtraerTextoPDFTool from '@/components/tools/ExtraerTextoPDFTool';

const faqs = [
  {
    q: '¿Por qué no obtengo texto de mi PDF escaneado?',
    a: 'Un PDF escaneado es básicamente una imagen fotográfica de un documento físico. No contiene texto digital, por lo que es necesario un OCR (reconocimiento óptico de caracteres) para leerlo. Esta herramienta extrae texto de PDFs nativos (generados digitalmente). Para PDFs escaneados necesitas una solución OCR.',
  },
  {
    q: '¿Se mantiene el formato y el orden del texto?',
    a: 'El texto se extrae en orden de aparición en el PDF, página por página. El formato visual (columnas, tablas, estilos) no se conserva en el texto plano resultante, aunque se añade una cabecera "--- Página X ---" para indicar los saltos de página.',
  },
  {
    q: '¿Puedo extraer texto de PDFs protegidos?',
    a: 'No si el PDF tiene una contraseña de usuario que restringe la apertura. Si el PDF tiene restricciones de copia pero no de apertura, la extracción puede funcionar dependiendo del nivel de cifrado.',
  },
  {
    q: '¿Qué hago después de extraer el texto?',
    a: 'Puedes copiarlo al portapapeles con el botón "Copiar todo" o descargarlo como archivo .txt. El texto es compatible con cualquier editor de texto, procesador de palabras o herramienta de IA como ChatGPT.',
  },
  {
    q: '¿Los archivos se envían al servidor?',
    a: 'No. PDF.js procesa el archivo completamente en tu navegador. El PDF y el texto extraído nunca se envían a ningún servidor externo.',
  },
];
---
<ToolLayout slug="extraer-texto-pdf" faqs={faqs}>
  <ExtraerTextoPDFTool client:load />
</ToolLayout>
