---
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import CategoryGrid from '@/components/ui/CategoryGrid';
import { TOOLS } from '@/lib/constants/tools';
import { PAGE_SEO, SITE } from '@/lib/constants/seo';
import '@/styles/global.css';

const tools = TOOLS.filter(t => t.domain === 'video');
const seo = PAGE_SEO['video'];
const domainLabel = 'Herramientas de vídeo';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={seo.canonical} />

    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image" content={SITE.ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="ToolsFoto — herramientas online para imagen, PDF, vídeo y audio" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={seo.canonical} />
    <meta property="og:site_name" content="ToolsFoto" />
    <meta property="og:locale" content="es_ES" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={SITE.twitterHandle} />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={SITE.ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": SITE.url },
        { "@type": "ListItem", "position": 2, "name": domainLabel, "item": seo.canonical },
      ],
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": seo.title,
      "description": seo.description,
      "url": seo.canonical,
      "inLanguage": "es",
      "isPartOf": { "@type": "WebSite", "name": "ToolsFoto", "url": SITE.url },
      "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": tools.length,
        "itemListElement": tools.map((t, i) => ({
          "@type": "ListItem",
          "position": i + 1,
          "name": t.name,
          "url": `${SITE.url}/${t.slug}`,
        })),
      },
    })} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon-192.png" />
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-JDPXVTKVCL"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-JDPXVTKVCL');
    </script>
  </head>
  <body>
    <Header />

    <div class="bg-[var(--color-text)] pt-14">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
        <nav class="flex items-center gap-2 text-xs text-[#888] mb-6 font-mono">
          <a href="/" class="hover:text-white transition-colors">Inicio</a>
          <span>/</span>
          <span style="color: #0BBFB0;">Vídeo</span>
        </nav>
        <div class="flex items-start justify-between gap-6 flex-wrap">
          <div>
            <h1 class="text-4xl sm:text-5xl font-extrabold text-white leading-tight mb-3" style="letter-spacing: -0.5px;">
              Herramientas de vídeo
            </h1>
            <p class="text-[#999] text-base max-w-xl leading-relaxed">
              Comprime, convierte, recorta y edita vídeos online gratis. Sin registro, todo se procesa en tu navegador.
            </p>
          </div>
          <div class="shrink-0 self-start">
            <span class="inline-flex items-center px-3 py-1.5 rounded-full bg-white/10 border border-white/20 text-sm font-medium text-white font-mono">
              {tools.length} herramientas
            </span>
          </div>
        </div>
      </div>
    </div>

    <main class="bg-[var(--color-tools-bg)] border-b border-[var(--color-tools-border)] py-10 min-h-[60vh]">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <CategoryGrid domain="video" client:load />
      </div>
    </main>

    <Footer />
  </body>
</html>
