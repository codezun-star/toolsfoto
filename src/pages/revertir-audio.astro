---
import ToolLayout from '@/components/layout/ToolLayout.astro';
import RevertirAudioTool from '@/components/tools/RevertirAudioTool';

const faqs = [
  {
    q: '¿Qué hace exactamente la herramienta de revertir audio?',
    a: 'Invierte el orden de las muestras del archivo de audio para que se reproduzca de atrás hacia adelante. El primer segundo del original pasa a ser el último, y viceversa. Es el equivalente sonoro de reproducir una cinta de cassette al revés.',
  },
  {
    q: '¿Para qué se usa revertir un audio?',
    a: 'Es una técnica clásica en producción musical y diseño de sonido: crear efectos de reverberación invertida (reverse reverb), pads atmosféricos, efectos especiales de ciencia ficción, o simplemente explorar cómo suena una grabación al revés.',
  },
  {
    q: '¿Qué formatos de audio admite?',
    a: 'Admite MP3, WAV, OGG, AAC y FLAC. El archivo resultante se descarga en el mismo formato que el original para mantener la compatibilidad con tus herramientas de audio.',
  },
  {
    q: '¿Se pierde calidad al revertir el audio?',
    a: 'No hay degradación de calidad perceptible. El filtro areverse de FFmpeg opera sobre el audio decodificado y lo re-codifica con los mismos parámetros. Para máxima calidad sin pérdida, usa archivos WAV o FLAC de origen.',
  },
  {
    q: '¿El procesamiento es en mi dispositivo?',
    a: 'Sí, completamente. FFmpeg.wasm procesa el audio en tu navegador sin enviar el archivo a ningún servidor. La privacidad de tus grabaciones está garantizada.',
  },
];
---
<ToolLayout slug="revertir-audio" faqs={faqs}>
  <RevertirAudioTool client:load />
</ToolLayout>
